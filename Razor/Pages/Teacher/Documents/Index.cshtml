@page
@model Razor.Pages.Teacher.Documents.IndexModel
@{
    ViewData["Title"] = "Teacher: Documents";
    ViewData["HideAppChrome"] = true;
    ViewData["BodyClass"] = "teacher-stitch-body";

    var documents = Model.DocumentList.Documents;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
}

<header class="teacher-stitch-topbar">
    <div class="teacher-stitch-brand">FPT UniRAG</div>
    <nav class="teacher-stitch-role-nav" aria-label="Teacher views">
        <a href="/Teacher/Dashboard#teacher-overview">Teacher</a>
        <a class="active" asp-page="/Teacher/Documents/Index">Documents</a>
    </nav>
    <div class="teacher-stitch-top-actions">
        <a asp-page="/Account/ChangePassword" class="teacher-stitch-account-button">
            <span class="material-symbols-outlined" aria-hidden="true">lock</span>
            Change Password
        </a>
        <a asp-page="/Account/ForgotPassword" class="teacher-stitch-account-button teacher-stitch-account-button-secondary">
            <span class="material-symbols-outlined" aria-hidden="true">key</span>
            Forgot Password
        </a>
        <form method="post" asp-page="/Index" asp-page-handler="Logout" class="teacher-stitch-logout-form">
            <button type="submit" class="teacher-stitch-logout-button">
                <span class="material-symbols-outlined" aria-hidden="true">logout</span>
                Logout
            </button>
        </form>
    </div>
</header>

<div class="teacher-stitch-shell">
    <aside class="teacher-stitch-sidebar" aria-label="Teacher navigation">
        <div class="teacher-stitch-sidebar-header">
            <div class="teacher-stitch-school-icon">
                <span class="material-symbols-outlined" aria-hidden="true">school</span>
            </div>
            <div>
                <h2>FPT Academic</h2>
                <p>Management Portal</p>
            </div>
        </div>

        <nav class="teacher-stitch-menu" aria-label="Teacher navigation">
            <a href="/Teacher/Dashboard#teacher-overview"><span class="material-symbols-outlined" aria-hidden="true">school</span>Teacher</a>
            <a class="active" asp-page="/Teacher/Documents/Index"><span class="material-symbols-outlined" aria-hidden="true">folder_open</span>Documents</a>
            <a asp-page="/Account/ChangePassword"><span class="material-symbols-outlined" aria-hidden="true">lock</span>Change Password</a>
            <a asp-page="/Account/ForgotPassword"><span class="material-symbols-outlined" aria-hidden="true">key</span>Forgot Password</a>
        </nav>
    </aside>

    <main class="teacher-stitch-main">
        <div class="teacher-stitch-page-title">
            <div>
                <h1>Documents</h1>
                <p>All uploaded documents across your assigned subjects.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="teacher-stitch-alert success" role="status">@Model.SuccessMessage</div>
        }

        <div class="teacher-stitch-alert success" role="status" data-subject-sync-message hidden></div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="teacher-stitch-alert warning" role="alert">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(value => value.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <section class="teacher-stitch-glass-card teacher-stitch-documents" aria-labelledby="teacher-documents-title">
            <div class="teacher-stitch-table-header">
                <div>
                    <h2 id="teacher-documents-title">Uploaded Documents</h2>
                    <span><span data-teacher-visible-documents>@documents.Count.ToString("N0")</span> TOTAL</span>
                </div>
            </div>

            <div class="teacher-stitch-table-wrap">
                <table class="teacher-stitch-table">
                    <thead>
                        <tr>
                            <th>Document Title</th>
                            <th>Subject</th>
                            <th>Chapter</th>
                            <th>File Name</th>
                            <th>Uploaded By</th>
                            <th>Upload Date</th>
                            <th>Status</th>
                            <th class="teacher-stitch-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (documents.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="teacher-stitch-empty">No documents have been uploaded yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var document in documents)
                            {
                                var statusClass = Model.GetStatusClass(document);
                                <tr data-document-row="@document.DocumentId" data-document-status="@document.Status.ToLowerInvariant()" data-subject-id="@document.SubjectId">
                                    <td>
                                        <div class="teacher-stitch-file-cell">
                                            <span class="teacher-stitch-file-icon @Model.GetFileIconClass(document)">
                                                <span class="material-symbols-outlined" aria-hidden="true">@Model.GetFileIconName(document)</span>
                                            </span>
                                            <strong>@document.Title</strong>
                                        </div>
                                    </td>
                                    <td>@Model.FormatSubject(document)</td>
                                    <td>@document.ChapterTitle</td>
                                    <td>@Model.FormatFileName(document)</td>
                                    <td>@document.UploadedByName</td>
                                    <td>@Model.FormatDocumentDate(document.CreatedAt)</td>
                                    <td>
                                        <span class="teacher-stitch-status @statusClass" data-document-status-badge>
                                            @if (statusClass == "indexing")
                                            {
                                                <span class="material-symbols-outlined" aria-hidden="true" data-document-status-icon>sync</span>
                                            }
                                            else
                                            {
                                                <i data-document-status-icon></i>
                                            }
                                            <span data-document-status-label>@Model.FormatStatus(document)</span>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="teacher-stitch-row-actions">
                                            <a asp-page="/Teacher/Documents/Details"
                                               asp-route-documentId="@document.DocumentId"
                                               title="View parsed chunks"
                                               class="@(document.Status.Equals("completed", StringComparison.OrdinalIgnoreCase) ? string.Empty : "disabled")"
                                               aria-disabled="@(!document.Status.Equals("completed", StringComparison.OrdinalIgnoreCase))"
                                               data-document-view-link>
                                                <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                                            </a>
                                            <form method="post"
                                                  asp-page-handler="Delete"
                                                  asp-route-documentId="@document.DocumentId"
                                                  onsubmit="return confirm('Delete this document?');">
                                                <button type="submit"
                                                        title="@(Model.CanDelete(document) ? "Delete document" : "Only the header teacher can delete chapter documents for this subject.")"
                                                        aria-label="Delete document"
                                                        disabled="@(!Model.CanDelete(document))">
                                                    <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>
    <script src="~/js/teacher-document-processing.js" asp-append-version="true"></script>
}
