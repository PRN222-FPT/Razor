@page
@model IndexModel
@{
    ViewData["Title"] = "Sign in";
    ViewData["HideAppChrome"] = true;
    ViewData["BodyClass"] = "login-page-body";
}

<section class="login-page">
    <div class="login-ambient" aria-hidden="true"></div>

    <main class="login-shell" aria-labelledby="login-title">
        <section class="login-card">
            <header class="login-header">
                <div class="login-logo-wrap" aria-hidden="true">
                    <svg class="login-logo" viewBox="0 0 24 24" role="img">
                        <path d="M21.5 9.1 12 4 2.5 9.1 12 14.2l7.5-4v5.1" />
                        <path d="M6.5 11.4v4.1c0 1.4 2.5 3 5.5 3s5.5-1.6 5.5-3v-4.1" />
                    </svg>
                </div>
                <h1 id="login-title">FPT Academic Assistant</h1>
                <p>Access your personalized academic intelligence assistant</p>
            </header>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
            }

            <form method="post" class="login-form" novalidate>
                <input asp-for="Input.ReturnUrl" type="hidden" />
                <div asp-validation-summary="All" class="login-validation-summary" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Input.Email">Email Address</label>
                    <div class="input-shell">
                        <svg class="input-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 4h16v16H4z" />
                            <path d="m4 7 8 6 8-6" />
                        </svg>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@fpt.edu.vn" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Password">Password</label>
                    <div class="input-shell">
                        <svg class="input-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="5" y="10" width="14" height="10" rx="2" />
                            <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        </svg>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Password" />
                        <button class="password-toggle" type="button" aria-label="Show password">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                <circle cx="12" cy="12" r="2.7" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="login-options">
                    <label class="login-check">
                        <input asp-for="Input.RememberMe" />
                        <span>Remember me</span>
                    </label>
                    <a asp-page="/Account/ForgotPassword" class="forgot-link">Forgot Password?</a>
                </div>

                <button type="submit" class="btn login-submit">
                    <span>Sign In</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14" />
                        <path d="m13 6 6 6-6 6" />
                    </svg>
                </button>
            </form>

            <footer class="login-card-footer">
                <p>Welcome to FPT Academic Portal</p>
                <div class="login-dot-row" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </footer>
        </section>
    </main>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
