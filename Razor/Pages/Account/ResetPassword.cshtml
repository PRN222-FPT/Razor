@page
@model Razor.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["HideAppChrome"] = true;
    ViewData["BodyClass"] = "login-page-body";
}

<section class="login-page">
    <main class="login-shell" aria-labelledby="reset-password-title">
        <section class="login-card">
            <header class="login-header">
                <div class="login-logo-wrap" aria-hidden="true">
                    <svg class="login-logo" viewBox="0 0 24 24" role="img">
                        <path d="M21.5 9.1 12 4 2.5 9.1 12 14.2l7.5-4v5.1" />
                        <path d="M6.5 11.4v4.1c0 1.4 2.5 3 5.5 3s5.5-1.6 5.5-3v-4.1" />
                    </svg>
                </div>
                <h1 id="reset-password-title">Reset Password</h1>
                <p>Choose a new password for your account.</p>
            </header>

            <form method="post" class="login-form" novalidate>
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Input.NewPassword"></label>
                    <div class="input-shell">
                        <svg class="input-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="5" y="10" width="14" height="10" rx="2" />
                            <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        </svg>
                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                        <button class="password-toggle" type="button" aria-label="Show new password">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                <circle cx="12" cy="12" r="2.7" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.ConfirmNewPassword"></label>
                    <div class="input-shell">
                        <svg class="input-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="5" y="10" width="14" height="10" rx="2" />
                            <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        </svg>
                        <input asp-for="Input.ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                        <button class="password-toggle" type="button" aria-label="Show confirmation password">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                <circle cx="12" cy="12" r="2.7" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn login-submit">
                    <span>Update Password</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14" />
                        <path d="m13 6 6 6-6 6" />
                    </svg>
                </button>
            </form>

            <footer class="login-card-footer">
                <p>Password updated?</p>
                <a asp-page="/Index">Back to sign in</a>
            </footer>
        </section>
    </main>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
