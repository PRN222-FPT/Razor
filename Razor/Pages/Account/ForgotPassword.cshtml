@page
@model Razor.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["HideAppChrome"] = true;
    ViewData["BodyClass"] = "login-page-body";
}

<section class="login-page">
    <main class="login-shell" aria-labelledby="forgot-password-title">
        <section class="login-card">
            <header class="login-header">
                <div class="login-logo-wrap" aria-hidden="true">
                    <svg class="login-logo" viewBox="0 0 24 24" role="img">
                        <path d="M21.5 9.1 12 4 2.5 9.1 12 14.2l7.5-4v5.1" />
                        <path d="M6.5 11.4v4.1c0 1.4 2.5 3 5.5 3s5.5-1.6 5.5-3v-4.1" />
                    </svg>
                </div>
                <h1 id="forgot-password-title">Forgot Password</h1>
                <p>We will send a reset link to your registered email address.</p>
            </header>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="alert alert-success" role="status">@Model.SuccessMessage</div>
            }

            <form method="post" class="login-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Input.Email"></label>
                    <div class="input-shell">
                        <svg class="input-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 4h16v16H4z" />
                            <path d="m4 7 8 6 8-6" />
                        </svg>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="name@fpt.edu.vn" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn login-submit">
                    <span>Send Reset Link</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M5 12h14" />
                        <path d="m13 6 6 6-6 6" />
                    </svg>
                </button>
            </form>

            <footer class="login-card-footer">
                <p>Remembered your password?</p>
                <a asp-page="/Index">Back to sign in</a>
            </footer>
        </section>
    </main>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
