<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FPT Academic Assistant</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Razor.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var hideAppChrome = ViewData["HideAppChrome"] as bool? == true;
    var bodyClass = ViewData["BodyClass"] as string;
}
<body class="@bodyClass">
    @if (!hideAppChrome)
    {
        <header>
            <nav class="navbar navbar-expand-lg app-navbar">
                <div class="container-fluid app-shell">
                    <a class="navbar-brand app-brand" asp-area="" asp-page="/Index">
                        <span class="brand-mark">FA</span>
                        <span>FPT Academic Assistant</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse justify-content-end">
                        <ul class="navbar-nav app-nav">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("student"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="" asp-page="/Student/Chat">Student Chat</a>
                                    </li>
                                }
                                @if (User.IsInRole("teacher"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="" asp-page="/Teacher/Dashboard">Teacher Dashboard</a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="/Account/ChangePassword">Change Password</a>
                                </li>
                                @if (User.IsInRole("admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="" asp-page="/Admin/Portal">Admin Portal</a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <form method="post" asp-page="/Index" asp-page-handler="Logout" class="logout-form">
                                        <button type="submit" class="nav-link logout-button">Sign out</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-page="/Index">Sign in</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }
    <div class="app-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @if (!hideAppChrome)
    {
        <footer class="app-footer">
            <div class="container-fluid app-shell">
                <span>&copy; 2026 FPT Academic Assistant</span>
                <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
