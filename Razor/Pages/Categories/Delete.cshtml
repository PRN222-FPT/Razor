@page "{id:int}"
@model DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<h1>Delete Category</h1>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<h3>Are you sure you want to delete this category?</h3>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Category.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Category.Description</dd>

    <dt class="col-sm-2">Products</dt>
    <dd class="col-sm-10">@Model.Category.ProductCount</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Category.CategoryId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</form>
