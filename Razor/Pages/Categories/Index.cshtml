@page
@model IndexModel
@{
    ViewData["Title"] = "Categories";
}

<h1>Categories</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</p>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Products</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Categories)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td><span class="badge bg-info">@item.ProductCount</span></td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-page="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-info">Details</a>
                    <a asp-page="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
