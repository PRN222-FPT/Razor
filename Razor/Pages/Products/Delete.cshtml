@page "{id:int}"
@model DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>

<h3>Are you sure you want to delete this product?</h3>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Product.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Product.Description</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Product.Price.ToString("C")</dd>

    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Product.StockQuantity</dd>

    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Product.CategoryName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Product.ProductId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</form>
